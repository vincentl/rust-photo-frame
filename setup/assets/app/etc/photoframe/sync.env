# Photo Frame Cloud Sync — /etc/photoframe/sync.env
#
# Uncomment and fill in ONE section below, then enable the sync timer:
#   sudo systemctl enable --now photoframe-sync.timer
#
# For full setup instructions see: docs/cloud-sync.md

# ── rclone (default, supports 40+ cloud services) ────────────────────────────
#
# Step 1: configure a named remote
#   rclone config
#
# Step 2: set RCLONE_REMOTE to <remote-name>:<path>
#
# RCLONE_REMOTE=gdrive:My Photos/Frame
# RCLONE_REMOTE=dropbox:Photos/Frame
# RCLONE_REMOTE=s3:my-bucket/frame
# RCLONE_REMOTE=onedrive:Frame Photos
# RCLONE_REMOTE=b2:my-bucket/frame

# Optional: override the default rclone transfer flags
# RCLONE_FLAGS=--checkers=8 --transfers=4 --retries=5 --copy-links

# ── rsync (LAN NAS or local server alternative) ───────────────────────────────
#
# SYNC_TOOL=rsync
# RSYNC_SOURCE=user@nas.local:/photos/frame/
# RSYNC_FLAGS=-av --delete
